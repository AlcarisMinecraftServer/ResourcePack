{
  "model": {
    "type": "select",
    "property": "custom_model_data",
    "fallback": {
      "type": "model",
      "model": "item/white_dye"
    },
    "cases": [
      {
        "when": "white_gold_coin",
        "model": {
          "type": "model",
          "model": "common:item/white_gold_coin"
        }
      },
            {
        "when": "big_gold_coin",
        "model": {
          "type": "model",
          "model": "common:item/big_gold_coin"
        }
            },
            {
        "when": "gold_coin",
        "model": {
          "type": "model",
          "model": "common:item/gold_coin"
        }
            },
            {
        "when": "silver_coin",
        "model": {
          "type": "model",
          "model": "common:item/silver_coin"
        }
            },
            {
        "when": "copper_coin",
        "model": {
          "type": "model",
          "model": "common:item/copper_coin"
        }
      }
    ]
  }
}